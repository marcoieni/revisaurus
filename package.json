{
    "name": "revisaur",
    "version": "0.1.0",
    "description": "Generate an Astro website with AI reviews for recently updated pull requests.",
    "type": "module",
    "bin": {
        "revisaur": "./dist/cli/index.js"
    },
    "scripts": {
        "build": "tsc -p tsconfig.json",
        "check": "tsc -p tsconfig.json --noEmit && astro check",
        "demo": "tsx src/cli/index.ts demo",
        "dev": "astro dev",
        "format": "prettier --write .",
        "generate": "tsx src/cli/index.ts generate",
        "site:build": "astro build",
        "test": "vitest run"
    },
    "engines": {
        "node": ">=24.0.0",
        "pnpm": ">=11.0.0"
    },
    "packageManager": "pnpm@11.1.1",
    "dependencies": {
        "@pierre/diffs": "^1.1.22",
        "commander": "^14.0.3",
        "execa": "^9.6.1",
        "fs-extra": "^11.3.5",
        "octokit": "^5.0.5",
        "smol-toml": "^1.6.1",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@astrojs/check": "^0.9.9",
        "@types/fs-extra": "^11.0.4",
        "@types/node": "^25.0.0",
        "astro": "^6.3.1",
        "prettier": "^3.8.3",
        "tsx": "^4.21.0",
        "typescript": "^6.0.3",
        "vitest": "^4.1.6"
    }
}
