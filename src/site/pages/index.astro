---
import { readFile } from "node:fs/promises";
import path from "node:path";
import ReviewApp from "../components/ReviewApp.astro";
import "../styles/global.css";

const dataDir = import.meta.env.REVISAUR_DATA_DIR ?? ".revisaur/data";
const workspace = import.meta.env.REVISAUR_WORKSPACE ?? process.cwd();
const siteDataPath = path.resolve(workspace, dataDir, "site.json");
const siteData = JSON.parse(await readFile(siteDataPath, "utf8"));
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Revisaur</title>
  </head>
  <body>
    <ReviewApp data={siteData} />
  </body>
</html>
