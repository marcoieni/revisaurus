---
import type { PullRequestReview, RepositoryConfig } from "../../types/revisaur.js";
import { repositoryLabel } from "../repositories.js";
import { publicAssetCssUrl, publicAssetPath } from "../runtime/assets.js";
import { collapseChevronSvg } from "../runtime/icons.js";
import FilterPicker from "./FilterPicker.astro";
import RepositoryPicker from "./RepositoryPicker.astro";
import ReviewIndicator from "./ReviewIndicator.astro";

const { data } = Astro.props;
const repositories = data.repositories as Array<Pick<RepositoryConfig, "id" | "name" | "provider" | "url" | "owner" | "repo">>;
const reviews = data.reviews as PullRequestReview[];
const initialRepo = data.repositories[0]?.id ?? "";
const authors = [
  ...reviews
    .reduce((authorsByName, review) => {
      const repoIds = authorsByName.get(review.pullRequest.author) ?? new Set<string>();
      repoIds.add(review.repoId);
      authorsByName.set(review.pullRequest.author, repoIds);
      return authorsByName;
    }, new Map<string, Set<string>>())
    .entries(),
]
  .map(([author, repoIds]) => ({ author, repoIds: [...repoIds] }))
  .sort((first, second) => first.author.localeCompare(second.author));
const assignees = [
  ...reviews
    .reduce((assigneesByName, review) => {
      for (const assignee of review.pullRequest.assignees ?? []) {
        const repoIds = assigneesByName.get(assignee) ?? new Set<string>();
        repoIds.add(review.repoId);
        assigneesByName.set(assignee, repoIds);
      }

      return assigneesByName;
    }, new Map<string, Set<string>>())
    .entries(),
]
  .map(([assignee, repoIds]) => ({ assignee, repoIds: [...repoIds] }))
  .sort((first, second) => first.assignee.localeCompare(second.assignee));
const projectUrl = "https://github.com/marcoieni/revisaur";
const logoUrl = publicAssetPath("logo.png");
const iconStyle = [
  ["--icon-file", "icons/file.svg"],
  ["--icon-moon", "icons/moon.svg"],
  ["--icon-square-split-horizontal", "icons/square-split-horizontal.svg"],
  ["--icon-square-split-vertical", "icons/square-split-vertical.svg"],
  ["--icon-sun", "icons/sun.svg"],
  ["--icon-text-align-justify", "icons/text-align-justify.svg"],
  ["--icon-text-wrap", "icons/text-wrap.svg"],
]
  .map(([name, path]) => `${name}: ${publicAssetCssUrl(path)}`)
  .join("; ");

function getUserUrl(review: PullRequestReview, user: string): string | undefined {
  if (review.pullRequest.provider !== "github" || user === "unknown") {
    return undefined;
  }

  return `https://github.com/${encodeURIComponent(user)}`;
}

function prReviewStateLabel(review: PullRequestReview): string {
  switch (review.pullRequest.reviewState) {
    case "approved":
      return "Approved";
    case "draft":
      return "Draft";
    case "ready":
      return "Ready for review";
  }
}
---

<main class="app-shell" style={iconStyle}>
  <header class="topbar">
    <div class="brand-heading">
      <a class="brand-logo-link" href={projectUrl} aria-label="Revisaur GitHub repository">
        <img src={logoUrl} alt="" width="56" height="57" />
      </a>
      <div>
        <h1>Revisaur</h1>
        <p>AI reviews in a static website.</p>
      </div>
    </div>
    <div class="topbar-controls">
      <fieldset class="theme-selector" aria-label="Color mode">
        <legend>Color mode</legend>
        <label class="has-tooltip">
          <input type="radio" name="theme" value="light" aria-label="Light mode" />
          <span class="theme-option theme-option-light" aria-hidden="true"></span>
          <span class="topbar-tooltip" aria-hidden="true">Light mode</span>
        </label>
        <label class="has-tooltip">
          <input type="radio" name="theme" value="dark" aria-label="Dark mode" />
          <span class="theme-option theme-option-dark" aria-hidden="true"></span>
          <span class="topbar-tooltip" aria-hidden="true">Dark mode</span>
        </label>
      </fieldset>
      <fieldset class="diff-overflow-selector" aria-label="Diff overflow">
        <legend>Diff overflow</legend>
        <label class="has-tooltip">
          <input type="radio" name="diff-overflow" value="scroll" aria-label="Scroll lines" />
          <span class="control-icon control-icon-text-align-justify" aria-hidden="true"></span>
          <span class="topbar-tooltip" aria-hidden="true">Scroll lines</span>
        </label>
        <label class="has-tooltip">
          <input type="radio" name="diff-overflow" value="wrap" aria-label="Wrap lines" />
          <span class="control-icon control-icon-text-wrap" aria-hidden="true"></span>
          <span class="topbar-tooltip" aria-hidden="true">Wrap lines</span>
        </label>
      </fieldset>
      <fieldset class="diff-layout-selector" aria-label="Diff layout">
        <legend>Diff layout</legend>
        <label class="has-tooltip">
          <input type="radio" name="diff-layout" value="split" aria-label="Split diff" />
          <span class="control-icon control-icon-square-split-horizontal" aria-hidden="true"></span>
          <span class="topbar-tooltip" aria-hidden="true">Split diff</span>
        </label>
        <label class="has-tooltip">
          <input type="radio" name="diff-layout" value="stacked" aria-label="Stacked diff" />
          <span class="control-icon control-icon-square-split-vertical" aria-hidden="true"></span>
          <span class="topbar-tooltip" aria-hidden="true">Stacked diff</span>
        </label>
      </fieldset>
      <div class="filter-controls" aria-label="Review filters">
        <RepositoryPicker repositories={repositories} initialRepo={initialRepo} />
        <FilterPicker
          id="author"
          label="Author"
          dialogTitle="Filter by author"
          placeholder="Filter authors"
          allOptionLabel="All authors"
          allOptionSearch="All authors all"
          detailKey="authors"
          eventName="author:selected"
          noSelectionLabel="No authors"
          pluralLabel="authors"
          options={authors.map(({ author, repoIds }) => ({
            id: author,
            label: author,
            repoIds,
            search: author,
            selected: true,
          }))}
        />
        <FilterPicker
          id="assignee"
          label="Assignee"
          dialogTitle="Filter by assignee"
          placeholder="Filter assignees"
          allOptionLabel="All assignees"
          allOptionSearch="All assignees all"
          detailKey="assignees"
          eventName="assignee:selected"
          noSelectionLabel="No assignees"
          pluralLabel="assignees"
          options={assignees.map(({ assignee, repoIds }) => ({
            id: assignee,
            label: assignee,
            repoIds,
            search: assignee,
            selected: true,
          }))}
        />
      </div>
    </div>
  </header>

  <section class="reviews" id="reviews">
    {
      repositories.map((repo) => (
        <section class="repo-section" data-repo={repo.id} hidden={repo.id !== initialRepo}>
          <div class="repo-heading">
            <div>
              <h2><a href={repo.url}>{repositoryLabel(repo)}</a></h2>
            </div>
          </div>
          {reviews
            .filter((review) => review.repoId === repo.id)
            .map((review) => {
              const authorUrl = getUserUrl(review, review.pullRequest.author);
              const assignees = review.pullRequest.assignees ?? [];

              return (
                <article
                  class="review"
                  data-author={review.pullRequest.author}
                  data-assignees={JSON.stringify(assignees)}
                  data-collapsed
                >
                  <header class="review-header">
                    <div class="review-heading">
                      <button class="review-collapse-toggle" type="button" aria-label="Expand pull request" aria-expanded="false">
                        <Fragment set:html={collapseChevronSvg} />
                      </button>
                      <div>
                        <a
                          class={`pr-number ${review.pullRequest.reviewState}`}
                          href={review.pullRequest.url}
                          data-tooltip={prReviewStateLabel(review)}
                          aria-label={`PR #${review.pullRequest.number}: ${prReviewStateLabel(review)}`}
                        >
                          #{review.pullRequest.number}
                        </a>{" "}
                        {review.pullRequest.title}
                        <p>
                          {authorUrl ? (
                            <a class="review-author" href={authorUrl}>{review.pullRequest.author}</a>
                          ) : (
                            review.pullRequest.author
                          )} · {review.reviewedCommit.slice(0, 8)}
                          {assignees.length > 0 && (
                            <>
                              {" "}· assignees:{" "}
                              {assignees.map((assignee, index) => {
                                const assigneeUrl = getUserUrl(review, assignee);

                                return (
                                  <>
                                    {index > 0 && <span>, </span>}
                                    {assigneeUrl ? (
                                      <a class="review-assignee" href={assigneeUrl}>{assignee}</a>
                                    ) : (
                                      <span>{assignee}</span>
                                    )}
                                  </>
                                );
                              })}
                            </>
                          )}
                        </p>
                      </div>
                    </div>
                    <div class="review-meta">
                      <ReviewIndicator review={review} />
                      <time datetime={review.reviewedAt}>{new Date(review.reviewedAt).toLocaleString()}</time>
                    </div>
                  </header>
                  <div class="review-body">
                    <div class="summary">{review.summary}</div>
                    {review.error && <pre class="error">{review.error}</pre>}
                    <div
                      class="diff-view"
                      data-patch={encodeURIComponent(review.diff)}
                      data-comments={encodeURIComponent(JSON.stringify(review.comments))}
                    >
                    </div>
                  </div>
                </article>
              );
            })}
        </section>
      ))
    }
  </section>
</main>

<script>
  import "../runtime/diffs.js";

  const sections = [...document.querySelectorAll<HTMLElement>(".repo-section")];
  const repositoryPicker = document.querySelector<HTMLElement>('[data-filter-picker][data-detail-key="repoIds"]');
  const authorPicker = document.querySelector<HTMLElement>('[data-filter-picker][data-detail-key="authors"]');
  const assigneePicker = document.querySelector<HTMLElement>('[data-filter-picker][data-detail-key="assignees"]');
  const repositoryOptions = [
    ...(repositoryPicker?.querySelectorAll<HTMLButtonElement>("[data-filter-option][data-option-id]") ?? []),
  ];
  const authorOptions = [
    ...(authorPicker?.querySelectorAll<HTMLButtonElement>("[data-filter-option][data-option-repos]") ?? []),
  ];
  const assigneeOptions = [
    ...(assigneePicker?.querySelectorAll<HTMLButtonElement>("[data-filter-option][data-option-repos]") ?? []),
  ];
  const themeSelector = document.querySelector<HTMLElement>(".theme-selector");
  const themeInputs = [...document.querySelectorAll<HTMLInputElement>('input[name="theme"]')];
  const diffOverflowSelector = document.querySelector<HTMLElement>(".diff-overflow-selector");
  const diffOverflowInputs = [...document.querySelectorAll<HTMLInputElement>('input[name="diff-overflow"]')];
  const diffLayoutSelector = document.querySelector<HTMLElement>(".diff-layout-selector");
  const diffLayoutInputs = [...document.querySelectorAll<HTMLInputElement>('input[name="diff-layout"]')];
  const allRepositoriesId = "__all";
  const allAuthorsId = "__all";
  const allAssigneesId = "__all";
  const urlFilterKeys = {
    repositories: "repositories",
    authors: "authors",
    assignees: "assignees",
  };
  let selectedRepoIds = [document.querySelector<HTMLElement>(".repo-section:not([hidden])")?.dataset.repo ?? allRepositoriesId];
  let selectedAuthors = [allAuthorsId];
  let selectedAssignees = [allAssigneesId];
  let applyingUrlFilters = false;
  type ColorMode = "light" | "dark";
  type DiffOverflow = "scroll" | "wrap";
  type DiffLayout = "split" | "stacked";

  const isColorMode = (value: string | null): value is ColorMode => value === "light" || value === "dark";
  const isDiffOverflow = (value: string | null): value is DiffOverflow => value === "scroll" || value === "wrap";
  const isDiffLayout = (value: string | null): value is DiffLayout => value === "split" || value === "stacked";
  const getInitialTheme = (): ColorMode => {
    const storedTheme = localStorage.getItem("revisaur:theme");
    if (isColorMode(storedTheme)) {
      return storedTheme;
    }

    return window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";
  };
  const getInitialDiffOverflow = (): DiffOverflow => {
    return localStorage.getItem("revisaur:diff-overflow") === "wrap" ? "wrap" : "scroll";
  };
  const getInitialDiffLayout = (): DiffLayout => {
    const storedLayout = localStorage.getItem("revisaur:diff-layout");
    return isDiffLayout(storedLayout) ? storedLayout : "split";
  };
  const optionIds = (options: HTMLButtonElement[]) =>
    options
      .map((option) => option.dataset.optionId)
      .filter((optionId): optionId is string => Boolean(optionId));
  const parseFilterParam = (params: URLSearchParams, key: string, validIds: Set<string>, fallback: string[]) => {
    const requestedIds = params
      .getAll(key)
      .flatMap((value) => value.split(","))
      .map((value) => value.trim())
      .filter(Boolean);

    if (requestedIds.length === 0) {
      return fallback;
    }

    const selectedIds = requestedIds.filter((id) => id === "__all" || id === "all" || validIds.has(id));
    const normalizedIds = selectedIds.map((id) => id === "all" ? "__all" : id);
    return normalizedIds.length > 0 ? [...new Set(normalizedIds)] : fallback;
  };
  const selectFilterOptions = (picker: HTMLElement | null, optionIds: string[]) => {
    picker?.dispatchEvent(
      new CustomEvent("filter:selected-options", {
        detail: { optionIds },
      }),
    );
  };
  const writeFilterParam = (params: URLSearchParams, key: string, selectedIds: string[]) => {
    if (selectedIds.length === 0) {
      params.delete(key);
      return;
    }

    params.set(key, selectedIds.join(","));
  };
  const updateFilterUrl = () => {
    if (applyingUrlFilters) return;

    const params = new URLSearchParams(window.location.search);
    writeFilterParam(params, urlFilterKeys.repositories, selectedRepoIds);
    writeFilterParam(params, urlFilterKeys.authors, selectedAuthors);
    writeFilterParam(params, urlFilterKeys.assignees, selectedAssignees);

    const query = params.toString();
    const nextUrl = `${window.location.pathname}${query ? `?${query}` : ""}${window.location.hash}`;
    window.history.replaceState(null, "", nextUrl);
  };
  const applyUrlFilters = () => {
    const params = new URLSearchParams(window.location.search);
    const repoIds = parseFilterParam(
      params,
      urlFilterKeys.repositories,
      new Set(optionIds(repositoryOptions)),
      selectedRepoIds,
    );
    const authorIds = parseFilterParam(
      params,
      urlFilterKeys.authors,
      new Set(optionIds(authorOptions)),
      selectedAuthors,
    );
    const assigneeIds = parseFilterParam(
      params,
      urlFilterKeys.assignees,
      new Set(optionIds(assigneeOptions)),
      selectedAssignees,
    );

    applyingUrlFilters = true;
    selectFilterOptions(repositoryPicker, repoIds);
    updateAuthorFilterOptions();
    updateAssigneeFilterOptions();
    selectFilterOptions(authorPicker, authorIds);
    selectFilterOptions(assigneePicker, assigneeIds);
    applyingUrlFilters = false;
    applyReviewFilters();
  };

  const applyTheme = (theme: ColorMode) => {
    document.documentElement.dataset.theme = theme;
    localStorage.setItem("revisaur:theme", theme);
    themeSelector?.setAttribute("aria-label", `Color mode: ${theme}`);
    for (const input of themeInputs) {
      input.checked = input.value === theme;
    }
    document.dispatchEvent(new CustomEvent("theme:selected", { detail: { theme } }));
  };
  const applyDiffOverflow = (overflow: DiffOverflow) => {
    document.documentElement.dataset.diffOverflow = overflow;
    localStorage.setItem("revisaur:diff-overflow", overflow);
    diffOverflowSelector?.setAttribute("aria-label", `Diff overflow: ${overflow}`);
    for (const input of diffOverflowInputs) {
      input.checked = input.value === overflow;
    }
    document.dispatchEvent(new CustomEvent("diff-overflow:selected", { detail: { overflow } }));
  };
  const applyDiffLayout = (layout: DiffLayout) => {
    document.documentElement.dataset.diffLayout = layout;
    localStorage.setItem("revisaur:diff-layout", layout);
    diffLayoutSelector?.setAttribute("aria-label", `Diff layout: ${layout}`);
    for (const input of diffLayoutInputs) {
      input.checked = input.value === layout;
    }
    document.dispatchEvent(new CustomEvent("diff-layout:selected", { detail: { layout } }));
  };

  applyTheme(getInitialTheme());
  applyDiffOverflow(getInitialDiffOverflow());
  applyDiffLayout(getInitialDiffLayout());

  for (const tooltipControl of document.querySelectorAll<HTMLElement>(".topbar-controls .has-tooltip")) {
    tooltipControl.addEventListener("pointerdown", () => {
      tooltipControl.dataset.tooltipDismissed = "true";
    });
    tooltipControl.addEventListener("pointerleave", () => {
      delete tooltipControl.dataset.tooltipDismissed;
    });
    tooltipControl.addEventListener("focusout", () => {
      delete tooltipControl.dataset.tooltipDismissed;
    });
  }

  for (const input of themeInputs) {
    input.addEventListener("change", () => {
      if (input.checked && isColorMode(input.value)) {
        applyTheme(input.value);
      }
    });
  }
  for (const input of diffOverflowInputs) {
    input.addEventListener("change", () => {
      if (input.checked && isDiffOverflow(input.value)) {
        applyDiffOverflow(input.value);
      }
    });
  }
  for (const input of diffLayoutInputs) {
    input.addEventListener("change", () => {
      if (input.checked && isDiffLayout(input.value)) {
        applyDiffLayout(input.value);
      }
    });
  }

  const applyReviewFilters = () => {
    const showAllRepositories = selectedRepoIds.includes(allRepositoriesId);
    const showAllAuthors = selectedAuthors.includes(allAuthorsId);
    const showAllAssignees = selectedAssignees.includes(allAssigneesId);

    for (const section of sections) {
      const repoMatches = showAllRepositories || selectedRepoIds.includes(section.dataset.repo ?? "");
      let hasVisibleReviews = false;

      for (const review of section.querySelectorAll<HTMLElement>(".review")) {
        const authorMatches = showAllAuthors || selectedAuthors.includes(review.dataset.author ?? "");
        const reviewAssignees = JSON.parse(review.dataset.assignees ?? "[]") as string[];
        const assigneeMatches = showAllAssignees || reviewAssignees.some((assignee) => selectedAssignees.includes(assignee));
        const reviewMatches = authorMatches && assigneeMatches;
        review.hidden = !reviewMatches;
        hasVisibleReviews = hasVisibleReviews || reviewMatches;
      }

      section.hidden = !repoMatches || ((!showAllAuthors || !showAllAssignees) && !hasVisibleReviews);
    }
  };

  const availableOptionsForSelectedRepositories = (options: HTMLButtonElement[]) => {
    const showAllRepositories = selectedRepoIds.includes(allRepositoriesId);
    return options
      .filter((option) => {
        if (showAllRepositories) return true;

        return (option.dataset.optionRepos ?? "")
          .split(",")
          .some((repoId) => selectedRepoIds.includes(repoId));
      })
      .map((option) => option.dataset.optionId)
      .filter((optionId): optionId is string => Boolean(optionId));
  };

  const updateAuthorFilterOptions = () => {
    authorPicker?.dispatchEvent(
      new CustomEvent("filter:available-options", {
        detail: {
          optionIds: availableOptionsForSelectedRepositories(authorOptions),
          selectAllIfEmpty: true,
        },
      }),
    );
  };

  const updateAssigneeFilterOptions = () => {
    assigneePicker?.dispatchEvent(
      new CustomEvent("filter:available-options", {
        detail: {
          optionIds: availableOptionsForSelectedRepositories(assigneeOptions),
          selectAllIfEmpty: true,
        },
      }),
    );
  };

  document.addEventListener("repo:selected", (event) => {
    selectedRepoIds = event instanceof CustomEvent && Array.isArray(event.detail.repoIds)
      ? event.detail.repoIds
      : [];
    updateAuthorFilterOptions();
    updateAssigneeFilterOptions();
    applyReviewFilters();
    updateFilterUrl();
  });

  document.addEventListener("author:selected", (event) => {
    selectedAuthors = event instanceof CustomEvent && Array.isArray(event.detail.authors)
      ? event.detail.authors
      : [];
    applyReviewFilters();
    updateFilterUrl();
  });

  document.addEventListener("assignee:selected", (event) => {
    selectedAssignees = event instanceof CustomEvent && Array.isArray(event.detail.assignees)
      ? event.detail.assignees
      : [];
    applyReviewFilters();
    updateFilterUrl();
  });

  applyUrlFilters();

  for (const button of document.querySelectorAll<HTMLButtonElement>(".review-collapse-toggle")) {
    const review = button.closest<HTMLElement>(".review");
    if (!review) {
      continue;
    }

    const updateReviewCollapseButton = (collapsed: boolean) => {
      button.title = collapsed ? "Expand pull request" : "Collapse pull request";
      button.setAttribute("aria-label", button.title);
      button.setAttribute("aria-expanded", String(!collapsed));
    };

    updateReviewCollapseButton(review.hasAttribute("data-collapsed"));
    button.addEventListener("click", () => {
      const collapsed = !review.hasAttribute("data-collapsed");
      review.toggleAttribute("data-collapsed", collapsed);
      updateReviewCollapseButton(collapsed);
    });
  }
</script>
