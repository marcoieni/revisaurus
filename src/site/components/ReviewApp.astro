---
import type { PullRequestReview, RepositoryConfig } from "../../types/revisaurus.js";

const { data } = Astro.props;
const repositories = data.repositories as Array<Pick<RepositoryConfig, "id" | "name" | "provider" | "url">>;
const reviews = data.reviews as PullRequestReview[];
const initialRepo = data.repositories[0]?.id ?? "";
const reviewedCount = reviews.filter((review) => review.status === "reviewed").length;
const commentCount = reviews.reduce((count, review) => count + review.comments.length, 0);
const pluralize = (count: number, label: string) => `${count} ${label}${count === 1 ? "" : "s"}`;
---

<main class="app-shell">
  <header class="topbar">
    <div class="brand">
      <h1>Revisaurus</h1>
      <p>AI pull request reviews generated from recent repository activity.</p>
    </div>
    <div class="topbar-stats" aria-label="Review summary">
      <span><strong>{reviews.length}</strong> PR{reviews.length === 1 ? "" : "s"}</span>
      <span><strong>{reviewedCount}</strong> reviewed</span>
      <span><strong>{commentCount}</strong> comment{commentCount === 1 ? "" : "s"}</span>
    </div>
    <div class="repo-picker">
      <label for="repo-select">Repository</label>
      <select id="repo-select">
        {repositories.map((repo) => <option value={repo.id} selected={repo.id === initialRepo}>{repo.name}</option>)}
      </select>
    </div>
  </header>

  <section class="reviews" id="reviews">
    {
      repositories.map((repo) => (
        <section class="repo-section" data-repo={repo.id} hidden={repo.id !== initialRepo}>
          <div class="repo-heading">
            <div>
              <h2>{repo.name}</h2>
              <a href={repo.url}>{repo.url}</a>
            </div>
            <span>{pluralize(reviews.filter((review) => review.repoId === repo.id).length, "review")}</span>
          </div>
          {reviews
            .filter((review) => review.repoId === repo.id)
            .map((review) => (
              <article class:list={["review", review.status === "failed" && "is-failed"]}>
                <header class="review-header">
                  <div>
                    <a href={review.pullRequest.url}>#{review.pullRequest.number} {review.pullRequest.title}</a>
                    <ul class="review-meta" aria-label="Pull request details">
                      <li>{review.pullRequest.author}</li>
                      <li>{review.reviewedCommit.slice(0, 8)}</li>
                      <li>{pluralize(review.comments.length, "comment")}</li>
                    </ul>
                  </div>
                  <div class="review-status">
                    <span class:list={["status-chip", review.status]}>{review.status}</span>
                    <time datetime={review.reviewedAt}>{new Date(review.reviewedAt).toLocaleString()}</time>
                  </div>
                </header>
                <div class="summary">{review.summary}</div>
                {review.error && <pre class="error">{review.error}</pre>}
                <div
                  class="diff-view"
                  data-patch={encodeURIComponent(review.diff)}
                  data-comments={encodeURIComponent(JSON.stringify(review.comments))}
                >
                </div>
              </article>
            ))}
        </section>
      ))
    }
  </section>
</main>

<script>
  import "../runtime/diffs.js";

  const input = document.querySelector<HTMLSelectElement>("#repo-select");
  const sections = [...document.querySelectorAll<HTMLElement>(".repo-section")];

  input?.addEventListener("change", () => {
    const selected = sections.find((section) => section.dataset.repo === input.value) ?? sections[0];

    for (const section of sections) {
      section.hidden = section !== selected;
    }
  });
</script>
