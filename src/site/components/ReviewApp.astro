---
import type { PullRequestReview, RepositoryConfig } from "../../types/revisaurus.js";
import RepositoryPicker from "./RepositoryPicker.astro";

const { data } = Astro.props;
const repositories = data.repositories as Array<Pick<RepositoryConfig, "id" | "name" | "provider" | "url">>;
const reviews = data.reviews as PullRequestReview[];
const initialRepo = data.repositories[0]?.id ?? "";

function getAuthorUrl(review: PullRequestReview): string | undefined {
  if (review.pullRequest.provider !== "github" || review.pullRequest.author === "unknown") {
    return undefined;
  }

  return `https://github.com/${encodeURIComponent(review.pullRequest.author)}`;
}
---

<main class="app-shell">
  <header class="topbar">
    <div>
      <h1>Revisaurus</h1>
      <p>AI pull request reviews generated from recent repository activity.</p>
    </div>
    <RepositoryPicker repositories={repositories} initialRepo={initialRepo} />
  </header>

  <section class="reviews" id="reviews">
    {
      repositories.map((repo) => (
        <section class="repo-section" data-repo={repo.id} hidden={repo.id !== initialRepo}>
          <div class="repo-heading">
            <div>
              <h2>{repo.name}</h2>
              <a href={repo.url}>{repo.url}</a>
            </div>
            <span>{reviews.filter((review) => review.repoId === repo.id).length} reviews</span>
          </div>
          {reviews
            .filter((review) => review.repoId === repo.id)
            .map((review) => {
              const authorUrl = getAuthorUrl(review);

              return (
                <article class="review">
                  <header class="review-header">
                    <div>
                      <a href={review.pullRequest.url}>#{review.pullRequest.number} {review.pullRequest.title}</a>
                      <p>
                        {authorUrl ? (
                          <a class="review-author" href={authorUrl}>{review.pullRequest.author}</a>
                        ) : (
                          review.pullRequest.author
                        )} · {review.status} · {review.reviewedCommit.slice(0, 8)}
                      </p>
                    </div>
                    <time datetime={review.reviewedAt}>{new Date(review.reviewedAt).toLocaleString()}</time>
                  </header>
                  <div class="summary">{review.summary}</div>
                  {review.error && <pre class="error">{review.error}</pre>}
                  <div
                    class="diff-view"
                    data-patch={encodeURIComponent(review.diff)}
                    data-comments={encodeURIComponent(JSON.stringify(review.comments))}
                  >
                  </div>
                </article>
              );
            })}
        </section>
      ))
    }
  </section>
</main>

<script>
  import "../runtime/diffs.js";

  const sections = [...document.querySelectorAll<HTMLElement>(".repo-section")];
  document.addEventListener("repo:selected", (event) => {
    const selectedRepo = event instanceof CustomEvent ? event.detail.repoId : "";
    for (const section of sections) {
      section.hidden = section.dataset.repo !== selectedRepo;
    }
  });
</script>
