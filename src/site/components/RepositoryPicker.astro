---
import type { RepositoryConfig } from "../../types/revisaur.js";
import { repositoryLabel } from "../repositories.js";

const { initialRepo, repositories } = Astro.props as {
  initialRepo: string;
  repositories: Array<Pick<RepositoryConfig, "id" | "name" | "provider" | "url" | "owner" | "repo">>;
};

const allRepositoriesId = "__all";
const selectedRepository = repositories.find((repo) => repo.id === initialRepo);
const initialLabel = selectedRepository ? repositoryLabel(selectedRepository) : initialRepo;
---

<div class="repo-picker" data-repo-combobox>
  <label for="repo-combobox">Repository</label>
  <div class="repo-combobox">
    <input
      id="repo-combobox"
      type="text"
      role="combobox"
      aria-autocomplete="list"
      aria-expanded="false"
      aria-controls="repo-options"
      aria-activedescendant=""
      autocomplete="off"
      spellcheck="false"
      value={initialLabel}
      data-selected-repos={initialRepo}
    />
    <button
      class="repo-combobox-toggle"
      type="button"
      aria-label="Show repositories"
      tabindex="-1"
    >
      <span class="topbar-tooltip" aria-hidden="true">Show repositories</span>
    </button>
  </div>
  <div id="repo-options" class="repo-options" role="listbox" aria-multiselectable="true" hidden>
    <button
      id="repo-option-all"
      type="button"
      role="option"
      data-repo-option
      data-repo-id={allRepositoriesId}
      data-repo-label="All repositories"
      data-repo-search="All repositories all"
      aria-selected="false"
    >
      <span>All repositories</span>
    </button>
    {
      repositories.map((repo, index) => (
        <button
          id={`repo-option-${index}`}
          type="button"
          role="option"
          data-repo-option
          data-repo-id={repo.id}
          data-repo-label={repositoryLabel(repo)}
          data-repo-search={`${repositoryLabel(repo)} ${repo.repo} ${repo.id} ${repo.provider}`}
          aria-selected={repo.id === initialRepo ? "true" : "false"}
        >
          <span>{repositoryLabel(repo)}</span>
        </button>
      ))
    }
  </div>
</div>

<script>
  const picker = document.querySelector<HTMLElement>("[data-repo-combobox]");
  const input = picker?.querySelector<HTMLInputElement>("#repo-combobox");
  const toggle = picker?.querySelector<HTMLButtonElement>(".repo-combobox-toggle");
  const listbox = picker?.querySelector<HTMLElement>("#repo-options");
  const options = [...(picker?.querySelectorAll<HTMLButtonElement>("[data-repo-option]") ?? [])];
  const allRepositoriesId = "__all";
  const repoOptions = options.filter((option) => option.dataset.repoId !== allRepositoriesId);
  let visibleOptions = [...options];
  let activeIndex = visibleOptions.findIndex((option) => option.getAttribute("aria-selected") === "true");

  const getSelectedRepoIds = () => {
    return repoOptions
      .filter((option) => option.getAttribute("aria-selected") === "true")
      .map((option) => option.dataset.repoId)
      .filter((repoId): repoId is string => Boolean(repoId));
  };

  const formatSelectedRepos = (selectedRepoIds: string[]) => {
    if (selectedRepoIds.length === 0) return "No repositories";
    if (selectedRepoIds.length === repoOptions.length) return "All repositories";
    if (selectedRepoIds.length === 1) {
      const selected = repoOptions.find((option) => option.dataset.repoId === selectedRepoIds[0]);
      return selected?.dataset.repoLabel ?? selectedRepoIds[0] ?? "";
    }

    return `${selectedRepoIds.length} repositories`;
  };

  const syncSelectedRepos = () => {
    if (!input || !picker) return;

    const selectedRepoIds = getSelectedRepoIds();
    const allSelected = selectedRepoIds.length === repoOptions.length;
    options
      .find((option) => option.dataset.repoId === allRepositoriesId)
      ?.setAttribute("aria-selected", String(allSelected));
    input.value = formatSelectedRepos(selectedRepoIds);
    input.dataset.selectedRepos = selectedRepoIds.join(",");
    picker.dispatchEvent(
      new CustomEvent("repo:selected", {
        bubbles: true,
        detail: { repoIds: allSelected ? [allRepositoriesId] : selectedRepoIds },
      }),
    );
  };

  const fuzzyScore = (value: string, query: string) => {
    const normalizedQuery = query.toLowerCase();
    const normalizedValue = value.toLowerCase();

    if (normalizedValue === normalizedQuery) return 0;

    const tokenIndex = normalizedValue.split(/[^a-z0-9]+/).findIndex((token) => token.startsWith(normalizedQuery));
    if (tokenIndex !== -1) return 5 + tokenIndex;

    const startsAt = normalizedValue.indexOf(normalizedQuery);
    if (startsAt !== -1) return 10 + startsAt;

    let cursor = 0;
    let firstMatch = -1;
    let lastMatch = -1;
    let gaps = 0;

    for (const character of normalizedQuery) {
      const matchIndex = normalizedValue.indexOf(character, cursor);
      if (matchIndex === -1) return Number.POSITIVE_INFINITY;
      if (lastMatch !== -1) gaps += matchIndex - lastMatch - 1;
      if (firstMatch === -1) firstMatch = matchIndex;
      lastMatch = matchIndex;
      cursor = matchIndex + 1;
    }

    return 100 + firstMatch * 2 + gaps * 10;
  };

  const setOpen = (open: boolean) => {
    if (!input || !listbox) return;

    listbox.hidden = !open;
    input.setAttribute("aria-expanded", String(open));
    if (!open) {
      input.setAttribute("aria-activedescendant", "");
    }
  };

  const setActive = (index: number) => {
    if (!input) return;

    activeIndex = index;
    options.forEach((option) => option.classList.remove("active"));
    const active = visibleOptions[activeIndex];
    if (!active) {
      input.setAttribute("aria-activedescendant", "");
      return;
    }

    active.classList.add("active");
    input.setAttribute("aria-activedescendant", active.id);
    active.scrollIntoView({ block: "nearest" });
  };

  const filterOptions = (queryOverride?: string) => {
    if (!input) return;

    const query = queryOverride ?? input.value.trim();
    visibleOptions = options
      .map((option, index) => {
        const search = option.dataset.repoSearch ?? "";
        const score = query === "" ? index : fuzzyScore(search, query);
        return { index, option, score };
      })
      .filter(({ score }) => Number.isFinite(score))
      .sort((first, second) => first.score - second.score || first.index - second.index)
      .map(({ option }) => option);

    [...visibleOptions, ...options.filter((option) => !visibleOptions.includes(option))].forEach((option) => {
      const matches = visibleOptions.includes(option);
      option.hidden = !matches;
      listbox?.append(option);
    });

    setActive(visibleOptions.length > 0 ? 0 : -1);
  };

  const toggleRepo = (option: HTMLButtonElement) => {
    if (!input || !picker) return;

    const selectedRepo = option.dataset.repoId ?? "";
    if (selectedRepo === allRepositoriesId) {
      const shouldSelectAll = option.getAttribute("aria-selected") !== "true";
      repoOptions.forEach((candidate) => candidate.setAttribute("aria-selected", String(shouldSelectAll)));
      syncSelectedRepos();
      return;
    }

    option.setAttribute("aria-selected", String(option.getAttribute("aria-selected") !== "true"));
    syncSelectedRepos();
  };

  input?.addEventListener("focus", () => {
    filterOptions("");
    setOpen(true);
    input.select();
  });

  input?.addEventListener("click", () => {
    filterOptions("");
    setOpen(true);
    input.select();
  });

  input?.addEventListener("input", () => {
    filterOptions();
    setOpen(true);
  });

  input?.addEventListener("keydown", (event) => {
    if (event.key === "ArrowDown" || event.key === "ArrowUp") {
      event.preventDefault();
      if (listbox?.hidden) {
        filterOptions("");
        setOpen(true);
      }
      const direction = event.key === "ArrowDown" ? 1 : -1;
      const nextIndex = visibleOptions.length
        ? (Math.max(activeIndex, 0) + direction + visibleOptions.length) % visibleOptions.length
        : -1;
      setActive(nextIndex);
    }

    if (event.key === "Enter") {
      const active = visibleOptions[activeIndex];
      if (active && !listbox?.hidden) {
        event.preventDefault();
        toggleRepo(active);
      }
    }

    if (event.key === "Escape") {
      input.value = formatSelectedRepos(getSelectedRepoIds());
      setOpen(false);
    }
  });

  toggle?.addEventListener("click", () => {
    if (!input || !listbox) return;

    const shouldOpen = listbox.hidden === true;
    toggle.dataset.tooltipDismissed = "true";
    input.focus();
    filterOptions("");
    setOpen(shouldOpen);
  });

  toggle?.addEventListener("pointerleave", () => {
    delete toggle.dataset.tooltipDismissed;
  });

  toggle?.addEventListener("blur", () => {
    delete toggle.dataset.tooltipDismissed;
  });

  options.forEach((option) => {
    option.addEventListener("click", () => toggleRepo(option));
  });

  document.addEventListener("pointerdown", (event) => {
    if (picker?.contains(event.target as Node)) return;

    if (input) input.value = formatSelectedRepos(getSelectedRepoIds());
    setOpen(false);
  });
</script>
