---
import type { RepositoryConfig } from "../../types/revisaur.js";
import { repositoryLabel } from "../repositories.js";
import FilterPicker from "./FilterPicker.astro";

const { initialRepo, repositories } = Astro.props as {
  initialRepo: string;
  repositories: Array<Pick<RepositoryConfig, "id" | "name" | "provider" | "url" | "owner" | "repo">>;
};
---

<FilterPicker
  id="repo"
  label="Repository"
  dialogTitle="Filter by repository"
  placeholder="Filter repositories"
  allOptionLabel="All repositories"
  allOptionSearch="All repositories all"
  detailKey="repoIds"
  eventName="repo:selected"
  noSelectionLabel="No repositories"
  pluralLabel="repositories"
  options={repositories.map((repo) => ({
    id: repo.id,
    label: repositoryLabel(repo),
    search: `${repositoryLabel(repo)} ${repo.repo} ${repo.id} ${repo.provider}`,
    selected: repo.id === initialRepo,
  }))}
/>
